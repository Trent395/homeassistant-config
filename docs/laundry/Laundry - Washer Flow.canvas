      "toSide": "left",
      "label": "started_at feeds"
    },
    {
      "id": "e_started_finished",
      "fromNode": "cycle_started",
      "fromSide": "bottom",
      "toNode": "cycle_finished",
      "toSide": "top",
      "label": "cycle_active=ON enables condition"
    },
    {
      "id": "e_finished_door",
      "fromNode": "cycle_finished",
      "fromSide": "right",
      "toNode": "door_opened",
      "toSide": "left"
    },
    {
      "id": "e_finished_waiting",
      "fromNode": "cycle_finished",
      "fromSide": "bottom",
      "toNode": "waiting_state",
      "toSide": "top",
      "label": "sets waiting state"
    },
    {
      "id": "e_waiting_dryer",
      "fromNode": "waiting_state",
      "fromSide": "right",
      "toNode": "dryer_clears",
      "toSide": "left"
    },
    {
      "id": "e_waiting_mildew",
      "fromNode": "waiting_state",
      "fromSide": "bottom",
      "toNode": "mildew_auto",
      "toSide": "top",
      "label": "waiting_for_dryer=ON enables"
    },
    {
